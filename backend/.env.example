# Copy this file to .env and fill in all values.
# In production, values are injected by Doppler — do not commit .env.

# ── Application ──────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=1.0.0

# ── Database (PostgreSQL via asyncpg) ────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/distroiq

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Anthropic ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=super-secret-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=service_role_...

# ── Cloudflare R2 ─────────────────────────────────────────────────────
R2_BUCKET=distroiq-uploads
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=<r2-access-key-id>
R2_SECRET_KEY=<r2-secret-access-key>

# ── Frontend ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
